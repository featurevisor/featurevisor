{
  "name": "@featurevisor/react",
  "version": "2.27.0",
  "description": "React package for Featurevisor",
  "main": "cjs/index.js",
  "module": "esm/index.js",
  "types": "cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./cjs/index.d.ts",
      "require": "./cjs/index.js",
      "import": "./node-esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "transpile": "rimraf cjs esm node-esm && tsc --project tsconfig.cjs.json && tsc --project tsconfig.esm.json && tsc --project tsconfig.node-esm.json && node -e \"require('fs').writeFileSync('node-esm/package.json', '{\\n  \\\"type\\\": \\\"module\\\"\\n}\\n')\"",
    "dist": "echo 'Nothing to dist here'",
    "build": "npm run transpile && npm run dist",
    "test": "jest --config jest.config.js"
  },
  "author": {
    "name": "Fahad Heylaal",
    "url": "https://fahad19.com"
  },
  "homepage": "https://featurevisor.com",
  "keywords": [
    "featurevisor",
    "feature",
    "features",
    "flags",
    "feature flags",
    "feature toggles",
    "feature management",
    "experimentation",
    "experiment",
    "experiments",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/featurevisor/featurevisor.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bugs": {
    "url": "https://github.com/featurevisor/featurevisor/issues"
  },
  "dependencies": {
    "@featurevisor/sdk": "2.27.0",
    "@featurevisor/types": "2.23.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jest-environment-jsdom": "^30.4.1"
  }
}
