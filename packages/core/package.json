  },
  "license": "MIT",
  "dependencies": {
    "@featurevisor/catalog": "3.1.0",
    "@featurevisor/parsers": "3.0.1",
    "@featurevisor/sdk": "3.0.1",
    "@featurevisor/types": "3.0.1",
    "axios": "^1.18.0",
    "tar": "^7.5.16",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  }
