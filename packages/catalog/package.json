{
  "name": "@featurevisor/catalog",
  "version": "2.27.0",
  "description": "Static catalog UI for Featurevisor projects",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "lib",
    "public",
    "src",
    "package.json"
  ],
  "scripts": {
    "transpile": "rimraf lib && tsc --project tsconfig.cjs.json",
    "dev1": "node scripts/dev.mjs --project ../../examples/example-1",
    "dev": "node scripts/dev.mjs",
    "build": "npm run transpile && vite build",
    "test": "jest --config jest.config.js --verbose",
    "preview": "vite preview --host 127.0.0.1 --port 3000"
  },
  "author": {
    "name": "Fahad Heylaal",
    "url": "https://fahad19.com"
  },
  "homepage": "https://featurevisor.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/featurevisor/featurevisor.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bugs": {
    "url": "https://github.com/featurevisor/featurevisor/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@featurevisor/types": "2.23.0",
    "react-markdown": "^8.0.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^22.10.2",
    "@types/react": "^18.0.29",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
