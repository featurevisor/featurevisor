{
  "name": "@featurevisor/vue",
  "version": "3.0.1",
  "description": "Vue.js package for Featurevisor",
  "main": "cjs/index.js",
  "module": "esm/index.js",
  "types": "cjs/index.d.ts",
  "files": [
    "cjs",
    "esm",
    "node-esm"
  ],
  "exports": {
    ".": {
      "types": "./cjs/index.d.ts",
      "require": "./cjs/index.js",
      "import": "./node-esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "transpile": "rimraf cjs esm node-esm && tsc --project tsconfig.cjs.json && tsc --project tsconfig.esm.json && tsc --project tsconfig.node-esm.json && node -e \"require('fs').writeFileSync('node-esm/package.json', '{\\n  \\\"type\\\": \\\"module\\\"\\n}\\n')\"",
    "build": "npm run transpile",
    "test": "jest --config jest.config.js --verbose --coverage ./src/*.spec.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "author": {
    "name": "Fahad Heylaal",
    "url": "https://fahad19.com"
  },
  "homepage": "https://featurevisor.com",
  "keywords": [
    "featurevisor",
    "feature",
    "features",
    "flags",
    "feature flags",
    "feature toggles",
    "feature management",
    "experimentation",
    "experiment",
    "experiments",
    "vue"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/featurevisor/featurevisor.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bugs": {
    "url": "https://github.com/featurevisor/featurevisor/issues"
  },
  "dependencies": {
    "@featurevisor/sdk": "3.0.1",
    "@featurevisor/types": "3.0.1",
    "vue": "^3.5.38"
  },
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@vue/test-utils": "^2.4.11",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1"
  }
}
