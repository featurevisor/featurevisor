{
  "name": "@featurevisor/sdk",
  "version": "2.27.0",
  "description": "Featurevisor SDK for Node.js and the browser",
  "main": "cjs/index.js",
  "module": "esm/index.js",
  "types": "cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./cjs/index.d.ts",
      "require": "./cjs/index.js",
      "import": "./node-esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "transpile": "rimraf cjs esm node-esm && tsc --project tsconfig.cjs.json && tsc --project tsconfig.esm.json && tsc --project tsconfig.node-esm.json && node -e \"require('fs').writeFileSync('node-esm/package.json', '{\\n  \\\"type\\\": \\\"module\\\"\\n}\\n')\"",
    "build": "npm run transpile",
    "test": "jest --config jest.config.js --verbose --coverage",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "author": {
    "name": "Fahad Heylaal",
    "url": "https://fahad19.com"
  },
  "homepage": "https://featurevisor.com",
  "keywords": [
    "featurevisor",
    "feature",
    "features",
    "flags",
    "feature flags",
    "feature toggles",
    "feature management",
    "experimentation",
    "experiment",
    "experiments"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/featurevisor/featurevisor.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bugs": {
    "url": "https://github.com/featurevisor/featurevisor/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@featurevisor/types": "2.23.0"
  }
}
